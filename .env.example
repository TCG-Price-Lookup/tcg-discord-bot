# Discord bot token from https://discord.com/developers/applications
# (Bot tab → Reset Token → copy)
DISCORD_TOKEN=

# Discord application ID — same page as the token, top of the General Information tab
DISCORD_CLIENT_ID=

# Optional: register commands to a single guild for instant updates during development.
# Leave blank in production for global registration.
DISCORD_GUILD_ID=

# TCG Price Lookup API key — get one free at https://tcgpricelookup.com/tcg-api
TCGLOOKUP_API_KEY=

# Optional: directory for the SQLite database (alerts, portfolios, server config).
# Defaults to ./data. Mount this as a volume in Docker to persist across restarts.
# DATA_DIR=./data

# Optional cron schedule overrides for background workers.
# Defaults are sensible — only set these if you know what you're doing.
# ALERTS_CRON=0 * * * *           # hourly alert price check
# SETS_CRON=0 14 * * *            # daily new-set scan at 14:00 UTC
# DAILY_REPORT_CRON=0 9 * * *     # daily market report at 09:00 UTC
